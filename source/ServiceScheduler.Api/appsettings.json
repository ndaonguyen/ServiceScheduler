{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AppDb": "Host=localhost;Port=5432;Database=servicescheduler;Username=servicescheduler;Password=servicescheduler"
  },
  "Jwt": {
    "Issuer": "ServiceScheduler",
